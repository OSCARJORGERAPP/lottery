# Plantilla de variables de entorno — copiar a .env.local y rellenar
# 127.0.0.1 (IPv4) a propósito: "localhost" puede resolver a ::1 y caer en otro
# mongod (ver lecciones en AGENTS.md). El código también acepta las variables de
# la plataforma CI: MONGO_HOST / MONGO_PORT / MONGO_USER / MONGO_PASSWORD / MONGO_DB
MONGODB_URI=mongodb://127.0.0.1:27017
MONGO_DB=lottery

# Firma de sesiones JWT y magic links
AUTH_SECRET=cambiar-por-un-secreto-largo-y-aleatorio

# Email que se convierte automáticamente en administrador
ADMIN_EMAIL=admin@lottery.dev

# Stripe (claves de test)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Magic link: en dev se imprime en consola; en producción se envía con Resend
RESEND_API_KEY=
APP_URL=http://localhost:3000
